# ── Base de datos ────────────────────────────────────────────────
DATABASE_URL="postgresql://dosnodos:dosnodos_dev@localhost:5432/dosnodos_crm"

# ── Aplicación ───────────────────────────────────────────────────
APP_URL="http://localhost:3000"
LANDING_URL="https://ventas.dosnodos.com.co"
DOS_NODOS_MAIN_URL="https://dosnodos.com.co"

# Secreto para firmar sesiones JWT (generar con: openssl rand -hex 32)
JWT_SECRET="cambia-esto-en-produccion"

# Secreto que deben enviar los cron jobs en el header `x-cron-secret`
CRON_SECRET="cambia-esto-en-produccion"

# Token que debe enviar la landing en el header `x-form-token`
# al capturar leads via POST /api/public/lead-capture
LANDING_FORM_TOKEN="cambia-esto-en-produccion"

# Token que debe enviar tu automatización externa en el header `x-import-token`
# al subir un CSV de leads via POST /api/public/leads-import
CSV_IMPORT_TOKEN="cambia-esto-en-produccion"

# ── Kapso (WhatsApp Business) ────────────────────────────────────
KAPSO_API_KEY=""
KAPSO_API_URL="https://app.kapso.ai/api/v1"
KAPSO_PHONE_NUMBER_ID=""
KAPSO_WEBHOOK_SECRET=""

# ── Apify (Google Maps Scraper) ──────────────────────────────────
# Sin token, el Lead Hunter (automático y el legado manual) corre en modo
# mock con datos de prueba realistas — útil para probar todo el pipeline
# sin gastar crédito de Apify.
APIFY_TOKEN=""
APIFY_GOOGLE_MAPS_ACTOR_ID="compass~crawler-google-places"

# ── Lead Hunter automático (cron diario, ver docs/lead-hunter.md) ─
# "false" desactiva el cron sin tener que quitarlo de vercel.json (la
# ejecución se registra igual, solo con 0 búsquedas).
LEAD_HUNTER_ENABLED="true"
# Tope de leads NUEVOS que se pueden crear por día (protección de costo).
LEAD_HUNTER_DAILY_LIMIT="20"
LEAD_HUNTER_CITY="Medellín"
LEAD_HUNTER_COUNTRY="Colombia"
# Zona horaria usada para calcular "el día" del lote (fuenteDetalle =
# lead-hunter-YYYY-MM-DD) y el límite diario — debe ser IANA válida.
LEAD_HUNTER_TIMEZONE="America/Bogota"
# Email que recibe el resumen de cada corrida (creados/duplicados/errores).
LEAD_HUNTER_NOTIFICATION_EMAIL=""
# Remitente del correo de resumen (debe ser un dominio verificado en Resend).
LEAD_HUNTER_FROM_EMAIL="Dos Nodos CRM <notificaciones@dosnodos.com.co>"

# ── IA (OpenAI — enriquecimiento del Lead Hunter) ─────────────────
# Sin API key, el Lead Hunter usa solo el motor de recomendación por reglas
# (nunca falla por falta de IA). Nota: distinto de ANTHROPIC_API_KEY abajo,
# que es para el asistente conversacional de WhatsApp.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# ── Resend (email transaccional) ──────────────────────────────────
RESEND_API_KEY=""

# ── IA (Anthropic Claude) ────────────────────────────────────────
# Sin API key, el asistente usa el motor de reglas (sin LLM).
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"

# ── Integraciones opcionales ─────────────────────────────────────
GOOGLE_CALENDAR_CLIENT_ID=""
GOOGLE_CALENDAR_CLIENT_SECRET=""
EMAIL_PROVIDER_API_KEY=""
